# Server-side only — never expose to the client or commit the real value.
# Local dev: copy to .env.local (gitignored). Vercel: set in Project Settings -> Environment Variables.
ANTHROPIC_API_KEY=sk-ant-...

# Embedding-gate cutoff (0-1). Queries whose best FAQ match scores below this
# are answered with a canned reply and never reach the paid API. See CHATBOT.md.
SIMILARITY_THRESHOLD=0.5
